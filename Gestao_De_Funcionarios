def bonificar_funcionario():
    if not lista_funcionarios:
        print('\nNenhum funcionário cadastrado.')
        return
    print('\nLista de Funcionários:')
    for i, f in enumerate(lista_funcionarios):
        print(f'{i + 1} - {f.nome} | CPF: {f.cpf} | Salário: R$ {f.salario:.2f}')
    cpf = input('\nDigite o CPF do funcionário a bonificar: ')
    for f in lista_funcionarios:
        if f.cpf == cpf:
            f.bonificar()
            print(f'\nBonus aplicado! Novo salário de {f.nome}: R$ {f.salario:.2f}')
            return
    print('\nFuncionário não encontrado.')

