class Funcionario():
    def __init__(self, nome, cpf, salario, departamento):
        self.nome = str(nome)
        self.cpf = str(cpf)
        self.salario = float(salario)
        self.departamento = str(departamento)

    def bonificar(self):
        self.salario = self.salario + (self.salario / 10)
         
        

class Gerente(Funcionario):
    def __init__(self, nome, cpf, salario, departamento, senha, funcionariosGerenciados): 
        super().__init__(nome, cpf, salario, departamento)  
        self.senha = str(senha) 
        self.funcionariosGerenciados = int(funcionariosGerenciados)

    def autenticarSenha(self, senha):
        if self.senha == senha:
            return True
        return False

    def bonificar(self):
        self.salario = self.salario + (self.salario / 15)

class Vendedor(Funcionario):
    def __init__(self, nome, cpf, salario, departamento, quantidadeVendas, comissao): 
        super().__init__(nome, cpf, salario, departamento)  
        self.quantidadaeVendas = int(quantidadeVendas) 
        self.comissao = float(comissao)

    def atualizaQuantidadeVendas(self, quantidadeVendas):
        self.quantidadaeVendas += quantidadeVendas

    def calculaSalario(self):
        self.salario += self.quantidadaeVendas + self.comissao

f1 = Funcionario('João', '32165498710', 1700.00, 'Vendas')  
g1 = Gerente('Giovana', '12345678901', 2651.00, 'Comercial', 'admin2026', 10)
v1 = Vendedor('Carolina', '98765432120', 2200.00, 'Vendas', 365, 10)

lista_funcionarios = [f1]
lista_gerentes = [g1]
lista_vendedores = [v1]
lista_geral = [lista_funcionarios, lista_gerentes, lista_vendedores]

def buscar_cargo_por_cpf(cpf, lista_geral):
    for l in lista_geral:
        for f in l:
            if f.cpf == cpf:
                return True
    return False

def cadastrar_funcionario():
    print('\nCadastrar novo funcionário: ')
    cpf = input('\nDigite o CPF do funcionário: ')
    if buscar_cargo_por_cpf(cpf, lista_geral):
        print('\nEsse CPF ja foi cadastrado.')
    else:
        novoNome = input('\nDigite o nome do funcionário: ')
        novoSalario = float(input('\nDigite o salário do funcionário: '))
        novoDepartamento = input('\nDigite o departamento do funcionário: ')

        novo_funcionario = Funcionario(novoNome, cpf, novoSalario, novoDepartamento)
        lista_funcionarios.append(novo_funcionario)
        print("\nFuncionário cadastrado com sucesso!")

