def atualizar_vendas_vendedor():
    if not lista_vendedores:
        print('\nNenhum vendedor cadastrado.')
        return
    print('\nLista de Vendedores:')
    for i, v in enumerate(lista_vendedores):
        print(f'{i + 1} - {v.nome} | CPF: {v.cpf} | Vendas: {v.quantidadaeVendas}')
    cpf = input('\nDigite o CPF do vendedor: ')
    for v in lista_vendedores:
        if v.cpf == cpf:
            qtd = int(input('\nDigite a quantidade de vendas a adicionar: '))
            v.atualizaQuantidadeVendas(qtd)
            print(f'\nQuantidade de vendas atualizada! Total de vendas de {v.nome}: {v.quantidadaeVendas}')
            return
    print('\nVendedor não encontrado.')

def calcular_salario_vendedor():
    if not lista_vendedores:
        print('\nNenhum vendedor cadastrado.')
        return
    print('\nLista de Vendedores:')
    for i, v in enumerate(lista_vendedores):
        print(f'{i + 1} - {v.nome} | CPF: {v.cpf} | Salário: R$ {v.salario:.2f}')
    cpf = input('\nDigite o CPF do vendedor: ')
    for v in lista_vendedores:
        if v.cpf == cpf:
            v.calculaSalario()
            print(f'\nSalário calculado! Novo salário de {v.nome}: R$ {v.salario:.2f}')
            return
    print('\nVendedor não encontrado.')

def listar_funcionarios():
