def autenticar_senha_gerente():
    if not lista_gerentes:
        print('\nNenhum gerente cadastrado.')
        return
    print('\nLista de Gerentes:')
    for i, g in enumerate(lista_gerentes):
        print(f'{i + 1} - {g.nome} | CPF: {g.cpf}')
    cpf = input('\nDigite o CPF do gerente: ')
