        print('\nNenhum funcionário cadastrado.')
        return
    nome = input('\nDigite o nome do funcionário (ou deixe em branco para listar todos): ')
    print('\n--- Lista de Funcionários ---')
    encontrou = False
    for f in lista_funcionarios:
        if nome == '' or nome.lower() in f.nome.lower():
            print(f'Nome: {f.nome} | CPF: {f.cpf} | Salário: R$ {f.salario:.2f} | Departamento: {f.departamento}')
            encontrou = True
    if not encontrou:
